{
	"name": "textmode.synth.js",
	"version": "1.7.1",
	"description": "Synth engine for textmode.js",
	"type": "module",
	"main": "./dist/textmode.synth.umd.js",
	"module": "./dist/textmode.synth.esm.js",
	"types": "./dist/types/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/textmode.synth.esm.js",
			"require": "./dist/textmode.synth.umd.js"
		}
	},
	"sideEffects": [
		"./src/bootstrap.ts",
		"./dist/textmode.synth.esm.js",
		"./dist/textmode.synth.umd.js"
	],
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "vite --port 5176 --host",
		"build:bundle": "vite build",
		"build:types": "tsc",
		"build": "npm run build:bundle && npm run build:types",
		"check": "npm run check:format && npm run check:deps && npm run lint && npm run lint:md && npm run check:types && npm run check:api-docs && npm run check:examples && npm run test && npm run build",
		"docs:links:add": "textmode-add-api-links",
		"check:api-docs": "textmode-check-api-docs",
		"check:api-docs:accessors": "textmode-check-api-docs --include-accessors",
		"check:examples": "textmode-check-examples",
		"dev:docs": "typedoc --options ./node_modules/@textmode/tooling-scripts/src/typedoc.member-pages.base.json --watch",
		"build:docs": "typedoc --options ./node_modules/@textmode/tooling-scripts/src/typedoc.member-pages.base.json",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest --coverage",
		"test:unit": "vitest run --project unit",
		"test:integration": "vitest run --project integration",
		"format": "prettier --write . --ignore-path node_modules/@textmode/tooling-scripts/src/prettierignore",
		"check:format": "prettier --check . --ignore-path node_modules/@textmode/tooling-scripts/src/prettierignore",
		"check:types": "tsc --noEmit",
		"lint:md": "markdownlint-cli2 --config package.json --configPointer /markdownlint-cli2",
		"lint:md:fix": "markdownlint-cli2 --config package.json --configPointer /markdownlint-cli2 --fix",
		"lint": "eslint --config ./node_modules/@textmode/eslint-config/index.js src",
		"prepare": "install-git-hooks",
		"check:deps": "check-deps"
	},
	"peerDependencies": {
		"textmode.js": ">=0.16.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.2.1",
		"@rollup/plugin-terser": "^1.0.0",
		"@types/node": "^26.1.1",
		"@vitest/ui": "^4.1.10",
		"esbuild": "^0.28.1",
		"eslint": "^10.6.0",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.8",
		"markdownlint-cli2": "^0.23.0",
		"prettier": "^3.9.4",
		"semantic-release": "^25.0.5",
		"textmode.js": "^0.17.0",
		"typedoc": "^0.28.20",
		"typedoc-plugin-frontmatter": "^1.3.1",
		"typedoc-plugin-markdown": "^4.12.0",
		"typedoc-vitepress-theme": "^1.1.3",
		"typescript": "^6.0.3",
		"vite": "^8.1.3",
		"vitest": "^4.1.10",
		"@textmode/commitlint-config": "^0.1.1",
		"@textmode/eslint-config": "^0.2.0",
		"@textmode/markdownlint-config": "^0.1.1",
		"@textmode/prettier-config": "^0.1.0",
		"@textmode/release-config": "^0.1.1",
		"@textmode/tooling-scripts": "^0.3.4",
		"@textmode/tsconfig": "^0.1.0",
		"@textmode/vitest-config": "^0.2.0"
	},
	"keywords": [
		"ascii",
		"petscii",
		"textmode",
		"canvas",
		"webgl",
		"creative-coding",
		"art",
		"design",
		"graphics",
		"ascii-art",
		"live-coding",
		"synthesis"
	],
	"author": "humanbydefinition",
	"license": "AGPL-3.0",
	"homepage": "https://code.textmode.art",
	"lint-staged": {
		"*": "prettier --ignore-unknown --ignore-path node_modules/@textmode/tooling-scripts/src/prettierignore --write"
	},
	"prettier": "@textmode/prettier-config",
	"commitlint": {
		"extends": [
			"@textmode/commitlint-config"
		]
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/humanbydefinition/textmode.synth.js.git"
	},
	"bugs": {
		"url": "https://github.com/humanbydefinition/textmode.synth.js/issues"
	},
	"typedocOptions": {
		"entryPoints": [
			"src/index.ts"
		],
		"out": "api/textmode.synth.js",
		"tsconfig": "tsconfig.json",
		"sort": [
			"source-order"
		],
		"textmodeApiBaseUrl": "https://code.textmode.art/api/textmode.synth.js",
		"textmodeStripApiSelfLinksMode": "minimal",
		"textmodeMemberPageKinds": [
			"method",
			"property",
			"accessor"
		]
	},
	"markdownlint-cli2": {
		"globs": [
			"**/*.md"
		],
		"ignores": [
			"api/**",
			"node_modules/**",
			"dist/**",
			"examples/**/*.md",
			"**/CHANGELOG.md",
			".agents/**"
		],
		"fix": false,
		"outputFormatters": [
			[
				"markdownlint-cli2-formatter-default"
			]
		],
		"config": {
			"extends": "@textmode/markdownlint-config"
		}
	}
}
